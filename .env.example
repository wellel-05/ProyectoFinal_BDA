# ElderCare — plantilla de variables de entorno
# Copia este archivo a .env y llena los valores

SECRET_KEY=cambia_esto_por_una_clave_segura_aleatoria

# Base de datos
DB_HOST=localhost
DB_NAME=asilo_db
DB_USER=tu_usuario_postgres
DB_PASSWORD=tu_contrasena_postgres
DB_PORT=5432

# Flask
FLASK_DEBUG=False
LOG_LEVEL=INFO

# Seguridad
WTF_CSRF_ENABLED=True

# IoT — API key para dispositivos externos
IOT_API_KEY=cambia_esta_api_key

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=eldercare_nosql
